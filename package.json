{
  "name": "gig-images",
  "version": "1.0.0",
  "description": "Razu — Fiverr gig cover image export system",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:css": "tailwindcss -i ./input.css -o ./output.css",
    "watch:css": "tailwindcss -i ./input.css -o ./output.css --watch",
    "export": "bun run build:css && node export.js"
  },
  "dependencies": {
    "puppeteer": "^22.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "vite": "^5.0.0"
  }
}
